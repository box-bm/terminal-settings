{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "modules": [
    { "type": "title", "format": "MacBook Pro" },
    "separator",
    "os",
    "host",
    "shell",
    "terminal",
    "cpu",
    "gpu",
    "memory",
    "disk",
    "battery",
    "uptime"
  ],
  "logo": {
    "type": "file",
    "source": "~/.config/fastfetch/logo.txt"
  }
}
